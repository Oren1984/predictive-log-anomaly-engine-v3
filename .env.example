# .env.example

# Purpose: Example environment variable configuration for the predictive-log-anomaly-engine project.

# Input: Environment variables for configuring the application.

# Output: Configured application behavior based on the provided environment variables.

# Used by: The predictive-log-anomaly-engine application.

# ============================================================
# predictive-log-anomaly-engine — Environment Variables
# ============================================================
# Copy this file to .env and fill in values as needed.
# Never commit .env to version control.

# ------------------------------------------------------------
# Stage 6 — Alerts: n8n Webhook Integration
# ------------------------------------------------------------

# Webhook URL for n8n integration.
# Leave empty to always use DRY_RUN (writes payloads to artifacts/n8n_outbox/).
N8N_WEBHOOK_URL=

# Set to "false" to enable live POSTing to N8N_WEBHOOK_URL.
# Default is "true" (safe dry-run: writes JSON files to disk, no network calls).
N8N_DRY_RUN=true

# HTTP request timeout in seconds for the n8n webhook POST.
N8N_TIMEOUT_SECONDS=5

# ------------------------------------------------------------
# Stage 7 — API: Server + Security + Observability
# ------------------------------------------------------------

# Bind address and port for the FastAPI server.
API_HOST=0.0.0.0
API_PORT=8000

# Secret API key clients must send in the X-API-Key header.
# Leave empty to disable key enforcement (useful for local dev).
API_KEY=changeme

# Set to "true" to disable X-API-Key enforcement entirely.
# Default is "false" (auth enabled).
DISABLE_AUTH=false

# Comma-separated URL prefixes that skip authentication.
# Default: /health,/metrics
PUBLIC_ENDPOINTS=/health,/metrics

# Set to "false" to disable the Prometheus /metrics endpoint.
METRICS_ENABLED=true

# Inference model used by InferenceEngine (baseline|transformer|ensemble).
MODEL_MODE=ensemble

# Sliding-window parameters.
# v1 baseline default: WINDOW_SIZE=50.
# v2 pipeline (MODEL_MODE=v2) REQUIRES WINDOW_SIZE=10 — it was trained at that size.
# Changing WINDOW_SIZE for v2 without retraining the LSTM, AE, and severity
# classifier will cause silent dimension mismatches at inference time.
WINDOW_SIZE=50
STRIDE=10

# Maximum number of recent alerts kept in the in-memory ring buffer.
ALERT_BUFFER_SIZE=200

# Per-stream-key alert cooldown in seconds (0 = fire every window).
ALERT_COOLDOWN_SECONDS=60.0

# ------------------------------------------------------------
# Stage 8 — Demo mode: fallback scorer + warmup traffic
# ------------------------------------------------------------

# DEMO_MODE=true makes the fallback scorer return DEMO_SCORE so alerts fire
# even without trained model files.  Never enable in production.
DEMO_MODE=false
DEMO_SCORE=2.0

# Warmup: ingest synthetic events on API startup to make the demo look alive.
# DEMO_WARMUP_ENABLED=true runs one batch of DEMO_WARMUP_EVENTS events.
# Set DEMO_WARMUP_INTERVAL_SECONDS>0 to repeat every N seconds.
DEMO_WARMUP_ENABLED=false
DEMO_WARMUP_EVENTS=75
DEMO_WARMUP_INTERVAL_SECONDS=0

# ------------------------------------------------------------
# V3 — Semantic layer (disabled by default; no-op when false)
# ------------------------------------------------------------

# Master switch for the semantic embedding layer.
# When false (default) no model is loaded and no embeddings are computed.
# Set to "true" to activate; requires sentence-transformers to be installed.
SEMANTIC_ENABLED=false

# Sentence-Transformers model identifier for log-line semantic embeddings.
# Only used when SEMANTIC_ENABLED=true.
# Default: all-MiniLM-L6-v2 (fast, 384-dim, good general-purpose quality).
SEMANTIC_MODEL=all-MiniLM-L6-v2

# Enable the explanation sub-system (requires SEMANTIC_ENABLED=true).
# When false (default) no explanations are generated.
EXPLANATION_ENABLED=false

# Explanation strategy: "rule-based" uses heuristic template matching.
# Future values: "llm" for LLM-backed explanation.
EXPLANATION_MODEL=rule-based

# LRU cache size for (text → embedding) pairs.
# 0 disables caching. Default: 1000.
SEMANTIC_CACHE_SIZE=1000
