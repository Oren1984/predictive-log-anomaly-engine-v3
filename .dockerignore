# .dockerignore (repo root)
#
# Must live at the build context root (repo root) for Docker to honour it.
# Build context is the repo root — see docker/docker-compose.yml: context: ..
#
# docker/.dockerignore is kept as a reference copy but is NOT used by Docker.

# Python
__pycache__/
*.pyc
*.pyo
*.pyd

# Virtual env
.venv/
.env

# Data (ALL heavy outputs)
data/raw/
data/intermediate/
data/processed/*.csv
data/processed/*.parquet

# Models
models/

# Reports (keep only markdown)
reports/*.csv
reports/*.json
reports/*.jsonl
artifacts/*.json

# Logs
ai_workspace/logs/

# Claude temp cwd markers
tmpclaude-*-cwd

# Synthetic data
data/synth/

# Windows junk
nul
tmpclaude-*-cwdnul
reports/*.
